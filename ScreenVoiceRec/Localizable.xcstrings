    "source.headphone.hint": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用麦克风、耳机麦克风或线路输入设备（通过 3.5 mm 或 USB 声卡）。需在「系统设置 › 隐私与安全性 › 麦克风」中授权本应用。"
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Uses the microphone, headset mic, or line-in (via 3.5 mm or USB audio). Allow microphone access for this app in System Settings › Privacy & Security › Microphone."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilise le micro, le micro-casque ou l’entrée ligne (prise 3,5 mm ou interface USB). Autorisez le micro pour cette app dans Réglages système › Confidentialité et sécurité › Microphone."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
