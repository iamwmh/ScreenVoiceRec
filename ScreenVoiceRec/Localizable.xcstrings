    "meter.hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The bar shows system audio level (about −55 dB to 0 dB). Time on the left is elapsed recording time (paused time excluded)."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "The bar shows system audio level (about −55 dB to 0 dB). Time on the left is elapsed recording time (paused time excluded)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La barre indique le niveau audio système (environ −55 dB à 0 dB). Le temps à gauche est la durée enregistrée (pause exclue)."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "La barre indique le niveau audio système (environ −55 dB à 0 dB). Le temps à gauche est la durée enregistrée (pause exclue)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "横条表示当前采集到的系统音频响度（约 -55dB～0dB）；左侧时间为已录时长（暂停不计入）。"
          }
        }
      }
    },
