    "error.no_audio_before_stop": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No audio captured: record longer and ensure the window or display is playing sound (don’t stop immediately after start)."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "No audio captured: record longer and ensure the window or display is playing sound (don’t stop immediately after start)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun audio capturé : enregistrez plus longtemps et assurez-vous que le son est lu (n’arrêtez pas tout de suite)."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun audio capturé : enregistrez plus longtemps et assurez-vous que le son est lu (n’arrêtez pas tout de suite)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未采集到音频：请多录几秒，并确保所选窗口或显示器正在播放声音（勿在刚点「开始」后立即停止）。"
          }
        }
      }
    },
    "error.permission.screen": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Screen Recording is required: System Settings → Privacy & Security → Screen & System Audio Recording, then allow this app."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Screen Recording is required: System Settings → Privacy & Security → Screen & System Audio Recording, then allow this app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’enregistrement d’écran est requis : Réglages système → Confidentialité et sécurité → Enregistrement d’écran et audio système, puis autorisez cette app."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "L’enregistrement d’écran est requis : Réglages système → Confidentialité et sécurité → Enregistrement d’écran et audio système, puis autorisez cette app."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要「屏幕录制」权限：请打开 系统设置 → 隐私与安全性 → 屏幕与系统录音，并允许本应用。"
          }
        }
      }
    },
